# =============================================================================
# CREDENCIALES DE ESCRITURA (admin) — solo para el responsable de carga
# =============================================================================

# CockroachDB Serverless — usuario admin
CRDB_CONNECTION=postgresql://user:<password>@host:26257/defaultdb?sslmode=verify-full

# MongoDB Atlas — cluster dimensions (usuario admin)
ATLAS_URI_DIMENSIONS=mongodb+srv://user:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB Atlas — cluster checkins + tips (usuario admin)
ATLAS_URI_CHECKINS_TIPS=mongodb+srv://user:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# Fracción de dimensions a cargar (1.0 = completo, 0.95 = 95% si hay overflow)
DIMENSIONS_SAMPLE_FRACTION=1.0

# Forzar re-lectura desde la nube e ignorar cache local (true = re-fetch)
REFRESH_CACHE=false

# Data load flags (cambiar a true después de una carga exitosa por destino)
CRDB_DATA_LOADED=false
ATLAS_DIMENSIONS_LOADED=false
ATLAS_BUSINESS_FACTS_LOADED=false
ATLAS_CHECKINS_TIPS_LOADED=false


# =============================================================================
# CREDENCIALES DE LECTURA (reader) — compartir con compañeros para analytics
# =============================================================================

# CockroachDB — usuario reader (solo SELECT en listings)
CRDB_CONNECTION_READ=postgresql://reader:<password>@host:26257/defaultdb?sslmode=verify-full

# Ruta al certificado SSL de CockroachDB (opcional en Linux/WSL — default: ~/.postgresql/root.crt)
# Descomentar y ajustar solo si el cert está en una ubicación no estándar
# CRDB_SSL_CERT=C:\Users\<usuario>\.postgresql\root.crt

# MongoDB Atlas — cluster dimensions (usuario reader, read-only)
ATLAS_URI_DIMENSIONS_READ=mongodb+srv://reader:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB Atlas — cluster checkins + tips (usuario reader, read-only)
ATLAS_URI_CHECKINS_TIPS_READ=mongodb+srv://reader:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
