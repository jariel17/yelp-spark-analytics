# =============================================================================
# CREDENCIALES DE ESCRITURA (admin) — responsable de carga
# =============================================================================

# CockroachDB Serverless — tabla users
CRDB_CONNECTION=postgresql://user:<password>@host:26257/defaultdb?sslmode=verify-full

# Aiven PostgreSQL — tabla reviews
AIVEN_CONNECTION=postgresql://avnadmin:<password>@host:port/defaultdb?sslmode=require
# Ruta al CA cert de Aiven (opcional — si se define usa sslmode=verify-ca)
# Descargar desde: Aiven Console → tu servicio → Connection Information → CA Certificate
# AIVEN_SSL_CERT=~/.aiven/ca.pem

# MongoDB Atlas M0 #1 — colección business
ATLAS_URI_BUSINESS=mongodb+srv://user:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB Atlas M0 #2 — colección tips
ATLAS_URI_TIPS=mongodb+srv://user:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB Atlas M0 #3 — colección checkins
ATLAS_URI_CHECKINS=mongodb+srv://user:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# Data load flags — cambiar a true después de una carga exitosa por script
# Para recargar un destino: volver a false y re-ejecutar el script correspondiente
CRDB_USERS_LOADED=false
AIVEN_REVIEWS_LOADED=false
ATLAS_BUSINESS_LOADED=false
ATLAS_TIPS_LOADED=false
ATLAS_CHECKINS_LOADED=false


# =============================================================================
# CREDENCIALES DE LECTURA (reader)
# =============================================================================

# CockroachDB — usuario reader (solo SELECT)
CRDB_CONNECTION_READ=postgresql://reader:<password>@host:26257/defaultdb?sslmode=verify-full

# Ruta al certificado SSL de CockroachDB (opcional en Linux/WSL — default: ~/.postgresql/root.crt)
# Descomentar y ajustar solo si el cert está en una ubicación no estándar
# CRDB_SSL_CERT=C:\Users\<usuario>\.postgresql\root.crt

# Aiven PostgreSQL — usuario reader
AIVEN_CONNECTION_READ=postgresql://reader:<password>@host:port/defaultdb?sslmode=require

# MongoDB Atlas M0 #1 — business (reader)
ATLAS_URI_BUSINESS_READ=mongodb+srv://reader:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB Atlas M0 #2 — tips (reader)
ATLAS_URI_TIPS_READ=mongodb+srv://reader:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB Atlas M0 #3 — checkins (reader)
ATLAS_URI_CHECKINS_READ=mongodb+srv://reader:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
